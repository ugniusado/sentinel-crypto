@inject DashboardStateService Dashboard

<div class="coin-card @SizeClass @PanicClass"
     style="@GlowStyle @HeatmapStyle"
     @key="Model.Symbol">

    @* ── Volume bar (right edge) ──────────────────────────────────────── *@
    <div class="volume-bar-track">
        <div class="volume-bar-fill @(Model.PriceChangePercent >= 0 ? "vol-up" : "vol-down")"
             style="height: @VolumeBarPct%"></div>
    </div>

    @* ── Header: Symbol + badges ─────────────────────────────────────── *@
    <div class="card-header">
        <div class="symbol-block">
            <span class="coin-symbol">@ShortSymbol</span>
            <span class="coin-pair">/USDT</span>
        </div>
        <div class="card-badges">
            @if (Model.IsPanic)
            {
                <span class="badge badge-panic">HIGH VOL</span>
            }
            <button class="fav-btn @(IsFavorite ? "fav-active" : "")"
                    @onclick="ToggleFavorite" title="Favorite">
                @(IsFavorite ? "★" : "☆")
            </button>
        </div>
    </div>

    @* ── Price with ghost-tick micro-animation ───────────────────────── *@
    <div class="price-wrapper">
        @if (_ghostPrice > 0)
        {
            <span class="price-ghost ghost-@_ghostDir" @key="@($"g{_renderCount}")">
                @FormatPrice(_ghostPrice)
            </span>
        }
        <span class="price-value price-enter-@_ghostDir" @key="@($"p{_renderCount}")">
            @FormatPriceStyled(Model.Price)
        </span>
    </div>

    @* ── 24h change ──────────────────────────────────────────────────── *@
    <div class="card-change @ChangeClass">
        @(Model.PriceChangePercent >= 0 ? "▲" : "▼")
        @Math.Abs(Model.PriceChangePercent).ToString("F2")%
    </div>

    @* ── Sparkline (medium + large) ──────────────────────────────────── *@
    @if (Model.Size != CardSize.Small && Model.SparklineData.Count >= 2)
    {
        <SparklineChart Points="Model.SparklineData"
                        IsPositive="Model.PriceChangePercent >= 0" />
    }

    @* ── Stats (medium + large) ──────────────────────────────────────── *@
    @if (Model.Size != CardSize.Small)
    {
        <div class="card-stats">
            <div class="stat">
                <span class="stat-label">24H HI</span>
                <span class="stat-value change-up">@FormatPrice(Model.High24h)</span>
            </div>
            <div class="stat">
                <span class="stat-label">24H LO</span>
                <span class="stat-value change-down">@FormatPrice(Model.Low24h)</span>
            </div>
            @if (Model.Size == CardSize.Large)
            {
                <div class="stat">
                    <span class="stat-label">VOL σ</span>
                    <span class="stat-value">@Model.Volatility.ToString("F4")</span>
                </div>
                <div class="stat">
                    <span class="stat-label">REL VOL</span>
                    <span class="stat-value @(Model.RelativeVolume > 2 ? "change-up" : "")">
                        @Model.RelativeVolume.ToString("F1")×
                    </span>
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public CoinModel Model { get; set; } = null!;

    // ── ShouldRender gate ──────────────────────────────────────────────────
    private decimal _lastRenderedPrice;
    private bool    _lastRenderedPanic;
    private bool    _forceRender;

    protected override bool ShouldRender()
    {
        if (_forceRender) { _forceRender = false; return true; }

        var significant = Model.HasSignificantChange() || Model.IsPanic != _lastRenderedPanic;
        if (!significant) return false;

        // ── Ghost tick setup ─────────────────────────────────────────────
        if (_lastRenderedPrice > 0 && Model.Price != _lastRenderedPrice)
        {
            _ghostPrice = _lastRenderedPrice;
            _ghostDir   = Model.Price > _lastRenderedPrice ? "up" : "down";
        }
        _renderCount++;
        _lastRenderedPrice = Model.Price;
        _lastRenderedPanic = Model.IsPanic;
        return true;
    }

    // ── Ghost tick state ──────────────────────────────────────────────────
    private decimal _ghostPrice;
    private string  _ghostDir = "up";
    private int     _renderCount;

    // ── Derived props ─────────────────────────────────────────────────────
    private string ShortSymbol => Model.Symbol.Replace("USDT", "");

    private bool IsFavorite => Dashboard.Favorites.Contains(Model.Symbol);

    private void ToggleFavorite()
    {
        Dashboard.ToggleFavorite(Model.Symbol);
        _forceRender = true;
        StateHasChanged();
    }

    private string SizeClass => Model.Size switch
    {
        CardSize.Large  => "card-large",
        CardSize.Medium => "card-medium",
        _               => "card-small"
    };

    private string PanicClass => Model.IsPanic ? "card-panic" : "";

    private string ChangeClass => Model.PriceChangePercent >= 0 ? "change-up" : "change-down";

    // Volatility glow — subtle radial box-shadow that intensifies with volatility
    private string GlowStyle
    {
        get
        {
            if (Model.IsPanic) return "";  // panic has its own CSS animation
            var v = (double)Model.Volatility;
            if (v < 0.5) return "";
            var rgb     = Model.PriceChangePercent >= 0 ? "16,185,129" : "239,68,68";
            var alpha   = Math.Min(0.08 + v / 40.0, 0.25);
            var spread  = (int)Math.Min(8 + v * 3, 32);
            return $"box-shadow: 0 0 {spread}px rgba({rgb},{alpha:F2}), inset 0 0 {spread / 2}px rgba({rgb},{alpha / 2:F2});";
        }
    }

    // Heatmap background — enabled via DashboardStateService toggle
    private string HeatmapStyle
    {
        get
        {
            if (!Dashboard.HeatmapEnabled) return "";
            var p = (double)Model.PriceChangePercent;
            return p switch
            {
                >  5  => "background: rgba(16,185,129,0.30);",
                >  2  => "background: rgba(16,185,129,0.18);",
                > 0.5 => "background: rgba(16,185,129,0.08);",
                < -5  => "background: rgba(239,68,68,0.30);",
                < -2  => "background: rgba(239,68,68,0.18);",
                < -0.5 => "background: rgba(239,68,68,0.08);",
                _     => ""
            };
        }
    }

    // Volume bar height: relative volume capped at 4x → 100%
    private int VolumeBarPct => (int)Math.Min(Model.RelativeVolume / 4.0m * 100m, 100m);

    // ── Price formatting ──────────────────────────────────────────────────
    // For micro-cap coins: "dim" the leading zeros so only moving digits pop
    private static MarkupString FormatPriceStyled(decimal price)
    {
        var s = FormatPrice(price);
        if (price >= 0.01m) return new MarkupString(s);

        // e.g. 0.00004821 → dim "0.0000" highlight "4821"
        var dotIdx = s.IndexOf('.');
        if (dotIdx < 0) return new MarkupString(s);

        var afterDot = s[(dotIdx + 1)..];
        var leadZeros = afterDot.TakeWhile(c => c == '0').Count();
        if (leadZeros == 0) return new MarkupString(s);

        var dim  = s[..(dotIdx + 1 + leadZeros)];
        var sig  = s[(dotIdx + 1 + leadZeros)..];
        return new MarkupString(
            $"<span class='price-dim'>{dim}</span><span class='price-sig'>{sig}</span>");
    }

    private static string FormatPrice(decimal price) => price switch
    {
        >= 1000 => price.ToString("N2"),
        >= 1    => price.ToString("N4"),
        _       => price.ToString("N6")
    };
}
