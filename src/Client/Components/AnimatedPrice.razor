@*
  Odometer / digital-clock animation.
  All layout-critical styles are inlined so browser CSS caching never breaks layout.
  CSS classes only carry the roll animations (purely decorative — no layout impact).
*@

<span class="anim-price" style="display:inline-flex;align-items:center;font-variant-numeric:tabular-nums;font-weight:600;letter-spacing:-.02em;">
    @for (var i = 0; i < _slots.Count; i++)
    {
        var slot = _slots[i];
        var pos  = i;
        var dir  = _isRising ? "up" : "dn";

        @if (slot.IsDigit)
        {
            <span style="position:relative;display:inline-block;overflow:hidden;" class="@(slot.IsDim ? "digit-dim" : "")">
                @* Hidden spacer — sets slot width/height via normal text flow *@
                <span aria-hidden="true"
                      style="visibility:hidden;display:block;line-height:1.2;user-select:none;">0</span>
                @* Visible digit — absolutely covers the spacer, animates on @key change *@
                <span class="digit-ink digit-@dir"
                      style="position:absolute;inset:0;display:block;line-height:1.2;text-align:center;"
                      @key="@($"{pos}:{slot.DigitValue}")">@slot.DigitValue</span>
            </span>
        }
        else
        {
            <span style="display:inline-block;line-height:1.2;vertical-align:middle;"
                  class="@(slot.IsDim ? "digit-dim" : "")"
                  @key="@($"s{pos}")">@slot.Char</span>
        }
    }
</span>

@code {
    [Parameter, EditorRequired] public decimal Value { get; set; }

    private decimal _prevValue;
    private bool    _isRising = true;

    private sealed record Slot
    {
        public bool IsDigit    { get; init; }
        public int  DigitValue { get; init; }
        public char Char       { get; init; }
        public bool IsDim      { get; init; }
    }

    private List<Slot> _slots = [];

    protected override void OnParametersSet()
    {
        _isRising  = Value >= _prevValue;
        _prevValue = Value;
        _slots     = BuildSlots(Value);
    }

    private static List<Slot> BuildSlots(decimal value)
    {
        var s      = FormatPrice(value);
        var slots  = new List<Slot>(s.Length);
        var dotIdx = s.IndexOf('.');

        bool dimMode         = value < 0.01m && dotIdx >= 0;
        bool pastSignificant = false;

        for (var i = 0; i < s.Length; i++)
        {
            var c = s[i];
            bool dim = false;
            if (dimMode && i > dotIdx && !pastSignificant)
            {
                if (c == '0') dim = true;
                else          pastSignificant = true;
            }
            slots.Add(char.IsDigit(c)
                ? new Slot { IsDigit = true,  DigitValue = c - '0', IsDim = dim }
                : new Slot { IsDigit = false, Char = c,              IsDim = dim });
        }

        return slots;
    }

    private static string FormatPrice(decimal price) => price switch
    {
        >= 1000 => price.ToString("N2"),
        >= 1    => price.ToString("N4"),
        _       => price.ToString("N6")
    };
}
